{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "djmc-cf",
  "main": ".open-next/worker.mjs",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [ "nodejs_compat" ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
